#%RAML 1.0 Trait
usage: Apply this trait to a GET method that supports pagination.
queryParameters:
  offset:
    description: "Offset to start pagination search results"
    type: integer
    required: false
    default: 0
    example: 20
  limit:
    description: "The number of results per page"
    type: integer
    required: false
    default: 10
    minimum: 1
    maximum: 200
    example: 25
