#%RAML 1.0 ResourceType
usage: Import this library to apply reusable resource type patterns

resourceTypes:


  collection:
    description: |
      Standard collection resource type for endpoints that manage a list of resources.
      Provides GET (list) and POST (create) operations with standard headers and errors.
      Apply to: /products
    usage: Apply to top-level collection endpoints (e.g., /products)
    get:
      description: Retrieve a list of <<resourcePathName | !pluralize | !uppercamelcase>> resources
      headers:
        Accept:
          description: Response media type – must be application/json
          type: string
          required: false
          default: "application/json"
          example: "application/json"
      responses:
        200:
          description: Successfully retrieved list of <<resourcePathName | !pluralize | !uppercamelcase>>
        400:
          description: Invalid query parameters provided
        401:
          description: Unauthorized – missing or invalid client credentials
        500:
          description: Internal Server Error

    post:
      description: Create a new <<resourcePathName | !singularize | !uppercamelcase>> resource
      headers:
        Content-Type:
          description: Request body media type – must be application/json
          type: string
          required: true
          default: "application/json"
          example: "application/json"
      responses:
        201:
          description: <<resourcePathName | !singularize | !uppercamelcase>> created successfully
          headers:
            Location:
              description: URI of the newly created resource
              type: string
        400:
          description: Invalid request body – validation failure
        401:
          description: Unauthorized – missing or invalid client credentials
        409:
          description: Conflict – resource with the same unique key already exists
        500:
          description: Internal Server Error


  productByIdResource:
    description: |
      Standard member resource type for endpoints that operate on a single resource.
      Provides PATCH (partial update) and DELETE operations with standard headers and errors.
      Apply to: /products/{productId}
    usage: Apply to single-resource endpoints (e.g., /products/{productId})
    uriParameters:
      <<resourcePathName | !singularize>>Id:
        description: Unique identifier of the <<resourcePathName | !singularize | !uppercamelcase>> resource
        type: string
        required: true

    patch:
      description: Partially update an existing <<resourcePathName | !singularize | !uppercamelcase>>
      headers:
        Content-Type:
          description: Request body media type – must be application/json
          type: string
          required: true
          default: "application/json"
          example: "application/json"
      responses:
        200:
          description: <<resourcePathName | !singularize | !uppercamelcase>> updated successfully
        400:
          description: Invalid request body or attempt to update a non-updatable field
        401:
          description: Unauthorized – missing or invalid client credentials
        404:
          description: <<resourcePathName | !singularize | !uppercamelcase>> not found
        500:
          description: Internal Server Error

    delete:
      description: Delete an existing <<resourcePathName | !singularize | !uppercamelcase>>
      responses:
        204:
          description: <<resourcePathName | !singularize | !uppercamelcase>> deleted successfully
        401:
          description: Unauthorized – missing or invalid client credentials
        404:
          description: <<resourcePathName | !singularize | !uppercamelcase>> not found
        500:
          description: Internal Server Error
